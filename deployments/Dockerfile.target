FROM golang:1.26-alpine AS builder

WORKDIR /app

# Cache dependency downloads
COPY go.mod go.sum ./
RUN go mod download

# Copy only the target script source
COPY scripts/target/ ./scripts/target/

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /webhook-target ./scripts/target

# --- Runtime stage ---
FROM alpine:3.20

COPY --from=builder /webhook-target /webhook-target

EXPOSE 9999

CMD ["/webhook-target"]
